LIBRARIAN_AUTH_TOKEN=replace-with-a-long-random-token

# Bind to 127.0.0.1 by default. For direct Tailnet access, set this to the
# VPS Tailscale IP, for example 100.x.y.z.
LIBRARIAN_PUBLISHED_HOST=127.0.0.1

# Optional comma-separated browser origins allowed to call POST endpoints.
# If you access the dashboard at http://100.x.y.z:3838, set that exact origin.
LIBRARIAN_ALLOWED_ORIGINS=
