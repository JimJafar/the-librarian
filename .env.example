# Copy to `.env` (kept out of git) and replace the placeholder tokens
# before running `docker compose -f docker/docker-compose.yml up -d`.
#
# Generate tokens with `openssl rand -base64 48`.

# ----- Admin tRPC: NO admin token (ADR 0008) -----
# There is no admin token. The admin tRPC API (/trpc/*) is served only on a
# trusted INTERNAL listener (loopback in the all-in-one; the `internal` docker
# network in compose) that is never published — so the token is no longer a
# network gate. The dashboard reaches that listener with no bearer; nothing to
# set here. (See the "Internal-only: admin tRPC listener" section below.)

# Agent token for normal `/mcp` traffic — the REAL network gate. Either this or
# LIBRARIAN_AGENT_TOKENS (or both) must be set for remote agents to authenticate.
LIBRARIAN_AGENT_TOKEN=replace-with-a-long-random-agent-token

# ----- Optional: per-agent token map -----
# Pins each token to one `agent_id` so writes are attributed to the right
# agent and identities can't be impersonated. Format:
# agent_id:token,agent_id:token. Either this or the shared
# LIBRARIAN_AGENT_TOKEN above must be set. Legacy fallback — prefer
# dashboard-minted tokens (the Tokens page) when the dashboard runs.
LIBRARIAN_AGENT_TOKENS=

# ----- Optional: encryption key for secret settings at rest (auto-generated if unset) -----
# An AES-256 key (NOT a bearer token) that encrypts secret settings stored in
# the DB — today, the memory curator's LLM API token. If unset, it is
# auto-generated to ${LIBRARIAN_DATA_DIR}/secret.key (mode 0600) on first boot
# and logged ONCE — SAVE THAT KEY: without it, secrets (and restored backups)
# cannot be decrypted. Set it here to manage the value yourself (e.g. to keep
# the key off the data volume); env always wins. Must be a 32-byte CSPRNG value
# as 64 hex chars — generate with `openssl rand -hex 32` (NOT the base64-48
# above). Once set, keep it STABLE: changing it makes previously-encrypted
# settings unreadable. Backups never contain the key — `the-librarian restore`
# prompts for it (or takes `--secret-key`) on a host that lacks it.
LIBRARIAN_SECRET_KEY=

# ----- Optional: scripted first-owner bootstrap -----
# Leave unset for the normal dashboard auth wizard and zero behaviour change.
# When set on an unowned server, this 32+ character secret arms a one-shot
# first-owner claim and redirects dashboard pages to /claim until it succeeds.
# Generate with `openssl rand -base64 48`, then mint the short-lived link with:
#   the-librarian auth mint-claim --email owner@example.com
# Redemption enables auth and writes
# ${LIBRARIAN_DATA_DIR}/bootstrap-claim.json (mode 0600); the flag and
# enabled-owner state each independently prevent reuse. See the self-host guide
# for the full arm, claim, and re-arm ceremonies.
LIBRARIAN_BOOTSTRAP_CLAIM_SECRET=

# ----- Optional: dashboard owner login — LEGACY env path (deprecated) -----
# RECOMMENDED: configure auth from the dashboard at /settings/auth instead — it
# stores config (password and/or GitHub/Google) in the data store, adds a
# username+password option, and enforces without a redeploy. The dashboard reaches
# the trusted internal tRPC listener directly (no admin token needed).
#
# The vars below are the DEPRECATED fallback for existing A1–A5 deployments: they
# still work (store config wins when present), but new installs should leave them
# unset and use the wizard. When set, the dashboard requires the single owner to
# sign in via GitHub/Google; JWT sessions — the dashboard never opens the store.
# AUTH_SECRET signs the session JWT (with the wizard it's derived from
# LIBRARIAN_SECRET_KEY, nothing to set). AUTH_URL is the dashboard's public origin;
# the OAuth callback is <AUTH_URL>/api/auth/callback/{github,google}.
LIBRARIAN_AUTH_ENABLED=false
AUTH_SECRET=
AUTH_URL=https://librarian.example.com
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Single-owner allowlist — set at least one. Account ids are the robust choice.
# GitHub id: the numeric id from https://api.github.com/users/<username>.
# Google id: the OIDC `sub`. LIBRARIAN_OWNER_EMAILS is a comma-separated,
# case-insensitive fallback that is ONLY honored for a provider-verified email
# (Google) — GitHub does not assert email verification, so GitHub owners must
# allowlist by account id, not email.
LIBRARIAN_OWNER_GITHUB_ID=
LIBRARIAN_OWNER_GOOGLE_ID=
LIBRARIAN_OWNER_EMAILS=

# ----- Optional: one published port through the dashboard -----
# Off by default. Set to true on the DASHBOARD process to proxy the complete
# public agent surface at clean same-origin paths: /mcp, /healthz, /primer.md,
# /transcript, and /ingest. The three bearer routes refuse to proxy unless the
# MCP server confirms agent authentication is active; configure
# LIBRARIAN_AGENT_TOKEN(S) and leave LIBRARIAN_ALLOW_NO_AUTH unset.
LIBRARIAN_SINGLE_PORT=false
# The origin agents should connect to in single-port mode. Set this to the
# dashboard's public HTTPS origin so the Connect page does not advertise :3838.
LIBRARIAN_PUBLIC_URL=

# ----- Optional: published host bindings -----
# By default both services bind to 127.0.0.1 on the host so they only
# accept local connections. Set these to a Tailnet IP (e.g. 100.x.y.z)
# to expose them on a private network. Use 0.0.0.0 only if you're sure
# about the network boundary.
LIBRARIAN_MCP_PUBLISHED_HOST=127.0.0.1
LIBRARIAN_DASHBOARD_PUBLISHED_HOST=127.0.0.1

# ----- Internal-only: admin tRPC listener (ADR 0008 — DO NOT publish) -----
# The admin tRPC API (/trpc/*) is served on its OWN listener, SEPARATE from the
# published agent port (which carries /mcp + /healthz + /primer.md). This keeps
# the admin surface — which can return DECRYPTED secrets — off the network:
# "defense by not-exposing". Only the dashboard talks to it, and it does so
# internally (loopback in the all-in-one; the docker network in compose).
#
# Keep LIBRARIAN_TRPC_HOST on loopback (127.0.0.1) unless you deliberately run
# a remote, separately-TLS'd dashboard. NEVER publish this port (no `-p`).
# LIBRARIAN_TRPC_PORT just needs to be a free in-container port.
#
# The two shipped deploys bind this listener as needed: the all-in-one image
# keeps it on 127.0.0.1:3840 (the dashboard reaches it over loopback); compose
# sets LIBRARIAN_TRPC_HOST=0.0.0.0 on the mcp-server so the dashboard container
# reaches it over the dedicated `internal` docker network (still unpublished).
LIBRARIAN_TRPC_HOST=127.0.0.1
LIBRARIAN_TRPC_PORT=3840

# The DASHBOARD side of the same link: the base URL its server-side tRPC client
# and /api/trpc proxy use to reach the internal listener above (it appends
# `/trpc`). This is DISTINCT from the agent /mcp URL — they are now different
# ports, so don't conflate them. The all-in-one sets it to the loopback listener
# (http://127.0.0.1:3840); compose sets it to http://mcp-server:3840 over the
# internal network. Unset, the dashboard falls back to LIBRARIAN_SERVER_URL for a
# single-server local dev run.
LIBRARIAN_TRPC_URL=

# ----- Optional: data volume ownership -----
# UID / GID the mcp-server container runs as. Must match the owner of the
# bind-mounted data directory (../data) so the container can read and write
# the vault and sidecar files. Defaults to 1001 when not set.
LIBRARIAN_DATA_UID=1001
LIBRARIAN_DATA_GID=1001

# ----- Optional: browser origin allow-list -----
# Same-origin browser requests are allowed by default. In single-port mode, list
# the dashboard's exact public HTTPS origin. Once this list is non-empty it must
# ALSO include the capture extension origin or /ingest is refused:
# https://memory.example.com,chrome-extension://<extension-id>
# Comma-separated; no trailing slash on HTTPS origins.
LIBRARIAN_ALLOWED_ORIGINS=
